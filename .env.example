# ==============================================================================
# 💈 STYLE MANAGER - BACKEND ENVIRONMENT CONFIGURATION TEMPLATE (.env.example)
# ==============================================================================
# Copia este archivo como '.env' en tu máquina local y completa los valores.
# ¡NUNCA subas el archivo '.env' real al repositorio de Git!
# ==============================================================================

# 🔌 1. CONFIGURACIÓN DEL SERVIDOR & PORT
PORT=3000
JWT_SECRET=reemplazar_con_firma_jwt_segura_en_produccion

# 📦 2. BASE DE DATOS (MongoDB Atlas o Local)
# Desarrollo local: mongodb://127.0.0.1:27017/BACKEND-BARBERSHOP
# Producción: URI de conexión provista por MongoDB Atlas
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/BACKEND-BARBERSHOP

# 🔔 3. NOTIFICACIONES EN TIEMPO REAL (Pusher)
# Obtén estas llaves creando una app gratuita en pusher.com
PUSHER_APP_ID=tu_pusher_app_id
PUSHER_KEY=tu_pusher_key
PUSHER_SECRET=tu_pusher_secret
PUSHER_CLUSTER=tu_pusher_cluster

# 📨 4. SERVICIO DE CORREOS (Resend)
# Obtén tu llave en resend.com para envíos masivos
RESEND_API_KEY=re_tu_resend_api_key_aqui
RESEND_FROM_EMAIL=notificaciones@tu-dominio.com

# ⏳ 5. COLAS Y RECORDATORIOS (Redis + Bull)
# Requerido para el motor de tareas programadas en segundo plano
# Desarrollo local: redis://127.0.0.1:6379
# Producción: URL de conexión de Redis (por ejemplo en Railway)
REDIS_URL=redis://default:password@host:port

# 🗄️ 6. ALMACENAMIENTO EN LA NUBE (MinIO / AWS S3)
# Usado para guardar fotos de perfil, imágenes de sedes y facturas
MINIO_ENDPOINT=tu-endpoint-s3-o-minio.host
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=tu_access_key
MINIO_SECRET_KEY=tu_secret_key
MINIO_BUCKET_NAME=backend-barbershop

# 💳 7. PASARELA DE PAGOS (Wompi)
# Llaves de integración provistas por Wompi Colombia (Pruebas o Producción)
WOMPI_PUB_KEY=pub_test_u_public_key_aqui
WOMPI_PRV_KEY=prv_test_u_private_key_aqui
WOMPI_INTEGRITY_SECRET=tu_integrity_secret_wompi

# 📱 8. INTEGRACIÓN DE WHATSAPP (Meta Cloud API)
# Obtén estos datos en developers.facebook.com > Tu Aplicación > WhatsApp
# URL formato: https://graph.facebook.com/v18.0/<PHONE_NUMBER_ID>/messages
WHATSAPP_API_URL=https://graph.facebook.com/v18.0/TU_PHONE_NUMBER_ID/messages
WHATSAPP_TOKEN=tu_token_de_acceso_permanente_a_meta_cloud
WHATSAPP_VERIFY_TOKEN=StyleManagerJevoWebhookToken

# 🧠 9. INTELIGENCIA ARTIFICIAL (Google Gemini API)
# Consigue una API Key gratuita en https://aistudio.google.com/
# Modelo utilizado: gemini-2.0-flash
GEMINI_API_KEY=tu_google_gemini_api_key_aqui
